# Copy this file to ".env" and fill in the real values.
# Vite exposes only variables prefixed with VITE_ to the browser bundle.

# Backend base URL the frontend calls.
# - Same machine (browser on the server): leave as localhost.
# - From another computer on the LAN: use the server's hostname/IP, e.g.
#     VITE_API_BASE=http://192.168.1.50:5000
VITE_API_BASE=http://localhost:5000

# Your Cesium ion access token (https://ion.cesium.com/tokens).
# Needed to load the citydb LoD2 base tileset (asset 96188) without the
# rate-limited default-token banner. Leave blank to use Cesium's default.
VITE_ION_TOKEN=
