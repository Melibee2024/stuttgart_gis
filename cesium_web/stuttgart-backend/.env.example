# Copy this file to ".env" and fill in the real values for THIS machine.
# The .env file is gitignored on purpose — credentials never go into git.

DB_USER=postgres
DB_HOST=localhost   # use "db" when running inside Docker Compose
DB_NAME=hft_db
DB_PASSWORD=CHANGE_ME
DB_PORT=5432

# Port the backend listens on (frontend defaults to http://localhost:5000)
PORT=5000
