# Python Virtual Environment (The heavy folder)
.venv/
__pycache__/
*.py[cod]

# PyCharm Settings (Individual laptop configs)
.idea/
*.iml

# Sensitive Data & Credentials
.env

# Large Spatial Data (Keep database local)
*.zip
*.gpkg
*.tif
*.las
media/img/*

# QGIS Backup files
*.qgs~
*.qgz~

# Ignore the local Cesium build files
cesium_web/Cesium/

# Optional: Ignore local data payloads if they are massive or auto-generated
cesium_web/buildings.geojson.json

# Other files to ignore#
cesium_web/stuttgart-backend/node_modules/
cesium_web/stuttgart-digital-twin/node_modules/