# =========================
# Python Virtual Environment
# =========================
.venv/
__pycache__/
*.py[cod]

# =========================
# IDE / Editor files
# =========================
.idea/
*.iml
.vscode/

# =========================
# Environment / Secrets
# =========================
.env
*.env
.env.

# =========================
# Python caches / logs
# =========================
*.log
*.sqlite3

# =========================
# GIS RAW DATA (IMPORTANT - prevents your issue)
# =========================
*.gml
*.zip
*.gpkg
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.tif
*.tiff
*.las
*.laz

# =========================
# Cesium / 3D Tiles / Digital Twin outputs
# =========================
*.pnts
*.b3dm
*.i3dm
*.cmpt
*.terrain
*.ktx2

cesium_web/stuttgart-digital-twin/public/tileset/
cesium_web/**/tileset/
cesium_web/**/build/
cesium_web/**/dist/
cesium_web/**/.cache/
cesium_web/stuttgart-backend/public/tiles/
# City base is fetched from the GitHub Release at CI-build time and copied here
# locally for dev — never commit it (keeps the repo lean).
cesium_web/stuttgart-digital-twin/public/tiles_citydb/
media/img/*

# Cesium library (already correct but extended safety)
cesium_web/Cesium/

# =========================
# Node dependencies
# =========================
node_modules/
cesium_web/**/node_modules/

# =========================
# QGIS / GIS project temp files
# =========================
*.qgs~
*.qgz~
*.mxd~
*.aux.xml

# =========================
# Auto-generated / exports
# =========================
cesium_web/buildings.geojson.json
output/
data/
exports/

# =========================
# OS junk
# =========================
.DS_Store
Thumbs.db
_archiv

# =========================
# QField sync service runtime data (keep local)
# =========================
qfc_sync_data/
py_updates/qfield_service/qfc_sync_data/
py_updates/qfield_service/web/
py_updates/qfield_service/sync_state.json

# QField synced photos (regenerated by the sync service — keep local).
# These are mirrored here by qfield_service and served by the Cesium backend
# at /media; the folder itself is kept via .gitkeep.
cesium_web/stuttgart-backend/media/*
!cesium_web/stuttgart-backend/media/.gitkeep

# Claude Code local (per-machine) settings
.claude/settings.local.json

# Sensitive data variants (keep example template tracked)
.env.*
!.env.example

# Node / Vite build output
dist/

# Generated 3D tiles (pg2b3dm output — regenerate on each machine, not committed)
cesium_web/stuttgart-backend/public/tiles_citydb/

# IFC source files (large, not committed)
*.ifc
