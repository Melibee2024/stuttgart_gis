# Python Virtual Environment (The heavy folder)
.venv/
__pycache__/
*.py[cod]

# PyCharm Settings (Individual laptop configs)
.idea/
*.iml

# Claude Code local (per-machine) settings
.claude/settings.local.json

# Sensitive Data & Credentials
.env
.env.*
!.env.example

# Large Spatial Data (Keep database local)
*.zip
*.gpkg
*.tif
*.las
media/img/*

# QGIS Backup files
*.qgs~
*.qgz~
# Node / Vite (match at any depth — earlier prefixed patterns missed cesium_web/)
node_modules/
dist/

# Generated 3D tiles (pg2b3dm output — regenerate on each machine, not committed)
cesium_web/stuttgart-backend/public/tiles/
