# =============================================
# QFieldCloud credentials (qfield_service)
# =============================================
QFC_USER=your_qfieldcloud_username
QFC_PASS=your_qfieldcloud_password
# Optional: use a token instead of user/pass
# QFC_TOKEN=your_token_here
QFC_PROJECT_ID=your_project_id_here

# =============================================
# PostGIS connection (qfield_service)
# ogr2ogr connection string format
# =============================================
PG_CONN=host=localhost port=5432 dbname=hft_db user=your_db_user password=your_db_password
PG_SCHEMA=qfield_data

# =============================================
# PostGIS connection (cesium backend)
# =============================================
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hft_db

# =============================================
# Photo folder — MUST be the same path for
# both services so photos land where the
# backend can serve them
# =============================================
PHOTO_WEB_DIR=../../cesium_web/stuttgart-backend/media

# =============================================
# ogr2ogr path (qfield_service)
# =============================================
OGR2OGR=C:/Program Files/QGIS 3.42.0/bin/ogr2ogr.exe

# =============================================
# Timing (qfield_service)
# =============================================
POLL_INTERVAL=10
PACKAGE_TIMEOUT=180
